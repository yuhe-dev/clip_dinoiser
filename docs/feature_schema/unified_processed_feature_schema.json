{
  "schema_version": "processed_feature_bundle.v1",
  "design_goal": "Convert raw per-sample feature arrays into stable, slice-finding-ready feature records while preserving original feature semantics.",
  "fit_policy": {
    "scope": "dataset_level",
    "rule": "Global bin edges are fit once per corpus split and then reused for every sample in that split.",
    "notes": [
      "Do not fit histogram edges independently per image.",
      "Robust ranges use merged raw values from the fitting split after any declared value_transform."
    ]
  },
  "record_format": {
    "top_level_fields": [
      "image_rel",
      "annotation_rel",
      "schema_version",
      "features"
    ],
    "field_roles": {
      "stored_fields": "Fields persisted in processed records for interpretability, auditing, visualization, and later feature-selection changes.",
      "model_input_fields": "Recommended subset of stored fields to assemble into the final numeric vector for slice finding."
    },
    "feature_block_common_fields": [
      "encoding",
      "empty_flag",
      "num_values",
      "log_num_values"
    ],
    "distribution_block_fields": [
      "encoding",
      "value_transform",
      "empty_flag",
      "num_values",
      "log_num_values",
      "hist",
      "summary",
      "model_input_fields"
    ],
    "profile_block_fields": [
      "encoding",
      "value_transform",
      "empty_flag",
      "num_values",
      "log_num_values",
      "profile",
      "delta_profile",
      "summary",
      "model_input_fields"
    ]
  },
  "dimensions": {
    "quality": {
      "schema_version": "quality.v1",
      "purpose": "Describe within-image quality distributions rather than collapsing quality to a single scalar.",
      "features": {
        "laplacian": {
          "raw_key": "laplacian_raw",
          "encoding": "distribution",
          "value_transform": "log1p",
          "num_bins": 12,
          "range_mode": "robust_global",
          "range_params": {
            "lower_quantile": 0.01,
            "upper_quantile": 0.99
          },
          "hist_normalization": "l1",
          "hist_field": "hist",
          "support_fields": [
            "empty_flag",
            "num_values",
            "log_num_values"
          ],
          "summary_fields": {
            "mean": "mean of transformed values",
            "std": "standard deviation of transformed values",
            "q10": "10th percentile of transformed values",
            "q50": "50th percentile of transformed values",
            "q90": "90th percentile of transformed values",
            "low_sharpness_mass": "sum of histogram bins 0-2",
            "high_sharpness_mass": "sum of histogram bins 9-11"
          },
          "model_input_fields": [
            "hist",
            "log_num_values",
            "empty_flag",
            "q50",
            "q90",
            "low_sharpness_mass"
          ]
        },
        "noise_pca": {
          "raw_key": "noise_pca_raw",
          "encoding": "distribution",
          "value_transform": "log1p",
          "num_bins": 12,
          "range_mode": "robust_global",
          "range_params": {
            "lower_quantile": 0.01,
            "upper_quantile": 0.99
          },
          "hist_normalization": "l1",
          "hist_field": "hist",
          "support_fields": [
            "empty_flag",
            "num_values",
            "log_num_values"
          ],
          "summary_fields": {
            "mean": "mean of transformed values",
            "std": "standard deviation of transformed values",
            "q10": "10th percentile of transformed values",
            "q50": "50th percentile of transformed values",
            "q90": "90th percentile of transformed values",
            "low_noise_mass": "sum of histogram bins 0-2",
            "high_noise_mass": "sum of histogram bins 9-11"
          },
          "model_input_fields": [
            "hist",
            "log_num_values",
            "empty_flag",
            "q50",
            "q90",
            "high_noise_mass"
          ]
        },
        "bga": {
          "raw_key": "bga_raw",
          "encoding": "distribution",
          "value_transform": "identity",
          "num_bins": 8,
          "range_mode": "fixed",
          "range_params": {
            "min": 0.0,
            "max": 1.0
          },
          "hist_normalization": "l1",
          "hist_field": "hist",
          "support_fields": [
            "empty_flag",
            "num_values",
            "log_num_values"
          ],
          "summary_fields": {
            "mean": "mean of raw values",
            "std": "standard deviation of raw values",
            "q10": "10th percentile of raw values",
            "q50": "50th percentile of raw values",
            "q90": "90th percentile of raw values",
            "low_bga_mass": "sum of histogram bins 0-1",
            "high_bga_mass": "sum of histogram bins 6-7"
          },
          "model_input_fields": [
            "hist",
            "log_num_values",
            "empty_flag",
            "q10",
            "q50",
            "low_bga_mass",
            "high_bga_mass"
          ]
        }
      }
    },
    "difficulty": {
      "schema_version": "difficulty.v1",
      "purpose": "Preserve heterogeneous difficulty semantics: profile-style small-object structure plus event-distribution difficulty values.",
      "features": {
        "small_ratio": {
          "raw_key": "small_ratio_raw",
          "encoding": "profile",
          "value_transform": "identity",
          "profile_length": 16,
          "profile_field": "profile",
          "derived_profile_field": "delta_profile",
          "support_fields": [
            "empty_flag",
            "num_values",
            "log_num_values"
          ],
          "summary_fields": {
            "first_active_bin": "index of the first non-zero delta bin normalized to [0, 1]",
            "mass_small_extreme": "sum of delta_profile bins 0-3",
            "mass_small_mid": "sum of delta_profile bins 4-9"
          },
          "model_input_fields": [
            "delta_profile",
            "log_num_values",
            "empty_flag",
            "mass_small_extreme",
            "mass_small_mid"
          ]
        },
        "visual_semantic_gap": {
          "raw_key": "visual_semantic_gap_raw",
          "encoding": "distribution",
          "value_transform": "log1p",
          "num_bins": 12,
          "range_mode": "robust_global",
          "range_params": {
            "lower_quantile": 0.01,
            "upper_quantile": 0.99
          },
          "hist_normalization": "l1",
          "hist_field": "hist",
          "support_fields": [
            "empty_flag",
            "num_values",
            "log_num_values"
          ],
          "summary_fields": {
            "mean": "mean of transformed values",
            "std": "standard deviation of transformed values",
            "q50": "50th percentile of transformed values",
            "q90": "90th percentile of transformed values",
            "high_gap_mass": "sum of histogram bins 9-11"
          },
          "model_input_fields": [
            "hist",
            "log_num_values",
            "empty_flag",
            "q50",
            "q90",
            "high_gap_mass"
          ]
        },
        "empirical_iou": {
          "raw_key": "empirical_iou_raw",
          "encoding": "distribution",
          "value_transform": "identity",
          "num_bins": 8,
          "range_mode": "fixed",
          "range_params": {
            "min": 0.0,
            "max": 1.0
          },
          "hist_normalization": "l1",
          "hist_field": "hist",
          "support_fields": [
            "empty_flag",
            "num_values",
            "log_num_values"
          ],
          "summary_fields": {
            "mean": "mean of raw values",
            "std": "standard deviation of raw values",
            "q10": "10th percentile of raw values",
            "q50": "50th percentile of raw values",
            "low_iou_mass": "sum of histogram bins 0-1",
            "high_iou_mass": "sum of histogram bins 6-7"
          },
          "model_input_fields": [
            "hist",
            "log_num_values",
            "empty_flag",
            "q10",
            "q50",
            "low_iou_mass",
            "high_iou_mass"
          ]
        }
      }
    },
    "coverage": {
      "schema_version": "coverage.v1",
      "purpose": "Preserve rank-aware embedding-space geometry for local density and prototype coverage instead of re-binning already aligned profiles.",
      "features": {
        "knn_local_density": {
          "raw_key": "knn_neighbor_distances_raw",
          "encoding": "profile",
          "value_transform": "identity_clamp_nonnegative",
          "profile_length_source": "feature_meta.knn_k",
          "profile_field": "profile",
          "derived_profile_field": "delta_profile",
          "support_fields": [
            "empty_flag",
            "num_values",
            "log_num_values"
          ],
          "summary_fields": {
            "mean": "mean neighbor distance",
            "std": "standard deviation of neighbor distances",
            "q10": "10th percentile neighbor distance",
            "q50": "50th percentile neighbor distance",
            "q90": "90th percentile neighbor distance",
            "nearest_distance": "profile[0]",
            "farthest_distance": "profile[-1]",
            "density_score": "1 / (eps + mean)"
          },
          "model_input_fields": [
            "profile",
            "q10",
            "q50",
            "q90",
            "nearest_distance",
            "density_score"
          ]
        },
        "prototype_distance": {
          "raw_key": "prototype_distances_raw",
          "encoding": "profile",
          "value_transform": "identity_clamp_nonnegative",
          "profile_length_source": "feature_meta.prototype_top_m",
          "profile_field": "profile",
          "derived_profile_field": "delta_profile",
          "support_fields": [
            "empty_flag",
            "num_values",
            "log_num_values"
          ],
          "summary_fields": {
            "mean": "mean prototype distance",
            "std": "standard deviation of prototype distances",
            "q10": "10th percentile prototype distance",
            "q50": "50th percentile prototype distance",
            "q90": "90th percentile prototype distance",
            "nearest_prototype_distance": "profile[0]",
            "prototype_margin_top2": "profile[1] - profile[0]",
            "prototype_margin_top5": "profile[4] - profile[0]"
          },
          "model_input_fields": [
            "profile",
            "q10",
            "q50",
            "q90",
            "nearest_prototype_distance",
            "prototype_margin_top2",
            "prototype_margin_top5"
          ]
        }
      }
    }
  },
  "empty_value_policy": {
    "distribution_encoding": {
      "hist": "all zeros",
      "summary_fields": "all zeros",
      "empty_flag": 1,
      "num_values": 0,
      "log_num_values": 0.0
    },
    "profile_encoding": {
      "profile": "all zeros with configured length",
      "derived_profile_field": "all zeros with configured length",
      "summary_fields": "all zeros",
      "empty_flag": 1,
      "num_values": 0,
      "log_num_values": 0.0
    }
  },
  "recommended_bundle_files": {
    "records_file_pattern": "data/data_feature/<dimension>/<dimension>_processed_features.npy",
    "schema_file_pattern": "data/data_feature/<dimension>/<dimension>_processed_schema.json",
    "config_file_pattern": "data/data_feature/<dimension>/<dimension>_processing_config.json",
    "summary_file_pattern": "data/data_feature/<dimension>/<dimension>_processed_summary.json"
  },
  "example_artifacts": {
    "single_record_example": "docs/feature_schema/example_processed_feature_record.json"
  }
}
